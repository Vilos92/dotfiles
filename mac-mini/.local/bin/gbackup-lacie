#!/bin/sh

# ==============================================================================
#
#                            !!! IMPORTANT !!!
#
# This script performs a ONE-WAY MIRROR backup.
#
# The LaCie drives ("Lacie" and "LaCie Small") are the DESTINATION. They are
# intended to be an exact copy of the source files from the T7 drive.
#
# Data flows FROM:
#   - /Volumes/T7/Vaults/Local Vault/media/
#   - /Volumes/Wokyis M.2 SSD - Storage/Vaults/Cloud Vault/
#   - /Volumes/T7/Vaults/GregZone Vault/
#   - /Volumes/T7/Vaults/Hobby Vault/
#
# Data flows TO:
#   - /Volumes/Lacie/
#   - /Volumes/LaCie Small/
#
# Because this script uses the --delete flag, any file that exists on the
# LaCie drives but NOT on the T7 drive will be PERMANENTLY DELETED from
# the LaCie drives during the sync.
#
# DO NOT STORE UNIQUE FILES IN THE LACIE DRIVE VAULTS.
#
# The only exception to this is the `Cold Local Vault`. These are permanently archived
# files that no longer add utility (they have been scrapped for parts).
#
# ==============================================================================

# --- 🛡️ Safety Check & Global Options ---
# This script is in DRY-RUN mode by default.
# Pass the --execute flag as the first argument to make real changes.
RSYNC_OPTS="-av --progress --delete" # Base options
if [ "$1" == "--execute" ]; then
    echo "✅ --execute flag detected. Live backup mode engaged."
else
    echo "🛡️ SAFE MODE: Running in simulation (dry-run) mode."
    RSYNC_OPTS="$RSYNC_OPTS --dry-run"
fi
echo "===================================================="


# --- Safety Checks ---
if [ ! -d "/Volumes/T7" ]; then
    echo "❌ ERROR: Samsung T7 drive not found at /Volumes/T7"
    echo "   Please ensure your Samsung T7 drive is connected and mounted"
    exit 1
fi

if [ ! -d "/Volumes/Lacie" ]; then
    echo "❌ ERROR: LaCie drive not found at /Volumes/Lacie"
    echo "   Please ensure your LaCie drive is connected and mounted"
    exit 1
fi

if [ ! -d "/Volumes/LaCie Small" ]; then
    echo "❌ ERROR: LaCie Small drive not found at /Volumes/LaCie Small"
    echo "   Please ensure your LaCie Small drive is connected and mounted"
    exit 1
fi

echo "✅ Source Samsung T7 drive found: /Volumes/T7"
echo "✅ Target LaCie drive found: /Volumes/Lacie"
echo "✅ Target LaCie Small drive found: /Volumes/LaCie Small"
echo "===================================================="


# --- Stage 1: Local Vault Backup (T7 -> LaCie) ---
echo "▶️  Starting Stage 1: Local Vault Backup"
# --- Configuration for Stage 1 ---
LV_SOURCE_DRIVE="/Volumes/T7/Vaults/Local Vault/media"
LV_DEST_DRIVE="/Volumes/Lacie/Local Vault/media"
LV_DIRS_TO_SYNC=( "concerts" "audio books" "music" "zim" "software" )

# --- Logic for Stage 1 ---
for dir in "${LV_DIRS_TO_SYNC[@]}"; do
    SOURCE_PATH="$LV_SOURCE_DRIVE/$dir/"
    DEST_PATH="$LV_DEST_DRIVE/$dir/"
    if [ -d "$SOURCE_PATH" ]; then
        echo "🔄 Syncing: $dir"
        rsync $RSYNC_OPTS "$SOURCE_PATH" "$DEST_PATH"
    else
        echo "⚠️  Skipping, not found: $SOURCE_PATH"
    fi
done
echo "----------------------------------------------------"


# --- Stage 2: Cloud Vault Backup (Wokyis -> LaCie Small) ---
echo "▶️  Starting Stage 2: Cloud Vault Backup"
# --- Configuration for Stage 2 ---
CV_SOURCE_BASE="/Volumes/Wokyis M.2 SSD - Storage/Vaults/Cloud Vault"
CV_DEST_DRIVE="/Volumes/LaCie Small/Cloud Vault"
CV_DIRS_TO_SYNC=( "GoPro" "video renders" )

if [ ! -d "$CV_SOURCE_BASE" ]; then
    echo "❌ ERROR: Cloud Vault not found at $CV_SOURCE_BASE"
    echo "   Please ensure your Wokyis drive is connected and mounted"
    exit 1
fi

# --- Logic for Stage 2 ---
for dir in "${CV_DIRS_TO_SYNC[@]}"; do
    SOURCE_PATH="$CV_SOURCE_BASE/$dir/"
    DEST_PATH="$CV_DEST_DRIVE/$dir/"
    if [ -d "$SOURCE_PATH" ]; then
        echo "🔄 Syncing: $dir"
        rsync $RSYNC_OPTS "$SOURCE_PATH" "$DEST_PATH"
    else
        echo "⚠️  Skipping, not found: $SOURCE_PATH"
    fi
done
echo "----------------------------------------------------"


# --- Stage 3: GregZone Vault Backup (T7 -> LaCie Small) ---
echo "▶️  Starting Stage 3: GregZone Vault Backup"
# --- Configuration for Stage 3 ---
GZ_SOURCE_BASE="/Volumes/T7/Vaults/GregZone Vault"
GZ_DEST_BASE="/Volumes/LaCie Small/GregZone Vault"

# --- Logic for Stage 3 ---
if [ -d "$GZ_SOURCE_BASE" ]; then
  echo "🔄 Syncing: Entire GregZone Vault"
  rsync $RSYNC_OPTS "$GZ_SOURCE_BASE/" "$GZ_DEST_BASE/"
else
  echo "⚠️  Skipping, not found: $GZ_SOURCE_BASE"
fi
echo "----------------------------------------------------"

# --- Stage 4: Hobby Vault Backup (T7 -> LaCie Small) ---
echo "▶️  Starting Stage 4: Hobby Vault Backup"
# --- Configuration for Stage 4 ---
HB_SOURCE_BASE="/Volumes/T7/Vaults/Hobby Vault"
HB_DEST_BASE="/Volumes/LaCie Small/Hobby Vault"

# --- Logic for Stage 4 ---
if [ -d "$HB_SOURCE_BASE" ]; then
  echo "🔄 Syncing: Entire Hobby Vault"
  rsync $RSYNC_OPTS "$HB_SOURCE_BASE/" "$HB_DEST_BASE/"
else
  echo "⚠️  Skipping, not found: $HB_SOURCE_BASE"
fi
echo "----------------------------------------------------"

echo "✅ All backup stages finished."
