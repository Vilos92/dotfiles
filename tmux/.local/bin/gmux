#!/bin/sh

# tmux maps '.' to '_' in session names on create; keep one canonical name everywhere.
to_session_name() {
    echo "$1" | tr '.' '_'
}

display_name_for_session() {
    session_name=$1
    for path in $project_paths; do
        [ -z "$path" ] && continue
        dir=$(basename "$path")
        if [ "$(to_session_name "$dir")" = "$session_name" ]; then
            echo "$dir"
            return 0
        fi
    done
    echo "$session_name"
}

project_path_for_session() {
    session_name=$1
    for path in $project_paths; do
        [ -z "$path" ] && continue
        if [ "$(to_session_name "$(basename "$path")")" = "$session_name" ]; then
            echo "$path"
            return 0
        fi
    done
}

project_paths_command="find \"$GREG_PROJECTS_PATH\""

if [ -d "$FRONTAPP_DIR" ]; then
    project_paths_command="$project_paths_command \"$FRONTAPP_DIR\""
fi

project_paths=$(eval "$project_paths_command -mindepth 1 -maxdepth 1 -type d")
project_dirs=$(echo "$project_paths" | xargs -n 1 basename)
projects=$(echo "$project_dirs" | tr '.' '_')

if [ -n "$1" ]; then
    session_name=$(to_session_name "$1")
    if echo "$projects" | grep -qx "$session_name"; then
        selected_project_path=$(project_path_for_session "$session_name")
        attach-tmux-session "$session_name" "$selected_project_path"
        exit 0
    fi
    attach-tmux-session "$session_name" "$2"
    exit 0
fi

sessions=$(tmux list-sessions 2>/dev/null | awk -F: '{ print $1 }')

gmux_options=$(printf "%s\n%s\n" "$projects" "$sessions" | sort -u | sed '/^$/d')

current_session=$(tmux list-sessions -F "#{session_name}" -f "#{session_attached}" 2>/dev/null)

select_options=$(echo "$gmux_options" | while read -r session_name; do
    display=$(display_name_for_session "$session_name")
    if [ "$session_name" = "$current_session" ]; then
        printf '🟢 %s\t%s\n' "$display" "$session_name"
    elif echo "$sessions" | grep -qx "$session_name"; then
        printf '🔵 %s\t%s\n' "$display" "$session_name"
    else
        printf '🌑 %s\t%s\n' "$display" "$session_name"
    fi
done)

selected_option=$(echo "$select_options" | sort -r | fzf --ansi --tmux 80% --delimiter="$(printf '\t')" --with-nth=1)

if [ -z "$selected_option" ]; then
    exit 0
fi

selected_project=$(printf '%s\n' "$selected_option" | cut -f2)
selected_project_path=$(project_path_for_session "$selected_project")

attach-tmux-session "$selected_project" "$selected_project_path"
