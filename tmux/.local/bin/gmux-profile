#!/bin/sh
# Profile gmux startup — writes timing breakdown to GMUX_PROFILE_LOG (default: /tmp/gmux-profile.log).
# Usage: gmux-profile          # profile list path (no fzf UI)
#        gmux-profile --fzf    # also time fzf until you pick or cancel

set -u

log=${GMUX_PROFILE_LOG:-/tmp/gmux-profile.log}
profile_fzf=0
[ "${1:-}" = "--fzf" ] && profile_fzf=1

now_ms() {
    perl -MTime::HiRes=time -e 'printf "%.0f\n", time()*1000'
}

elapsed_ms() {
    start=$1
    end=$2
    echo $((end - start))
}

to_session_name() {
    echo "$1" | tr '.' '_'
}

display_name_for_session() {
    session_name=$1
    _old_ifs=$IFS
    IFS='
'
    for path in $project_paths; do
        [ -z "$path" ] && continue
        dir=$(basename "$path")
        if [ "$(to_session_name "$dir")" = "$session_name" ]; then
            IFS=$_old_ifs
            echo "$dir"
            return 0
        fi
    done
    IFS=$_old_ifs
    echo "$session_name"
}

: >"$log"
t0=$(now_ms)
last=$t0

tick() {
    label=$1
    now=$(now_ms)
    printf '%s\t+%sms\ttotal=%sms\n' "$label" "$(elapsed_ms "$last" "$now")" "$(elapsed_ms "$t0" "$now")" >>"$log"
    last=$now
}

{
    echo "=== gmux profile $(date '+%Y-%m-%dT%H:%M:%S%z') ==="
    echo "GREG_PROJECTS_PATH=${GREG_PROJECTS_PATH:-<unset>}"
    echo "FRONTAPP_DIR=${FRONTAPP_DIR:-<unset>}"
    echo "PWD=$PWD"
    echo "TMUX=${TMUX:-<unset>}"
    echo
} >>"$log"

tick "start"

project_paths_command="find \"${GREG_PROJECTS_PATH:-}\""
if [ -d "${FRONTAPP_DIR:-}" ]; then
    project_paths_command="$project_paths_command \"$FRONTAPP_DIR\""
fi

project_paths=$(eval "$project_paths_command -mindepth 1 -maxdepth 1 -type d" 2>>"$log")
project_path_count=$(printf '%s\n' "$project_paths" | sed '/^$/d' | wc -l | tr -d ' ')
tick "find project dirs (count=$project_path_count)"

projects=""
_old_ifs=$IFS
IFS='
'
for path in $project_paths; do
    [ -z "$path" ] && continue
    projects="$projects$(to_session_name "$(basename "$path")")
"
done
IFS=$_old_ifs
project_count=$(printf '%s\n' "$projects" | sed '/^$/d' | wc -l | tr -d ' ')
tick "build projects list (count=$project_count)"

sessions=$(tmux list-sessions 2>>"$log" | awk -F: '{ print $1 }')
session_count=$(printf '%s\n' "$sessions" | sed '/^$/d' | wc -l | tr -d ' ')
tick "tmux list-sessions (count=$session_count)"

gmux_options=$(printf "%s\n%s\n" "$projects" "$sessions" | sort -u | sed '/^$/d')
option_count=$(printf '%s\n' "$gmux_options" | sed '/^$/d' | wc -l | tr -d ' ')
tick "merge+sort options (count=$option_count)"

current_session=$(tmux list-sessions -F "#{session_name}" -f "#{session_attached}" 2>>"$log")
tick "tmux current attached session"

grep_count=0
select_options=$(echo "$gmux_options" | while read -r session_name; do
    display=$(display_name_for_session "$session_name")
    if [ "$session_name" = "$current_session" ]; then
        printf '🟢 %s\t%s\n' "$display" "$session_name"
    elif echo "$sessions" | grep -Fqx "$session_name"; then
        grep_count=$((grep_count + 1))
        printf '🔵 %s\t%s\n' "$display" "$session_name"
    else
        printf '🌑 %s\t%s\n' "$display" "$session_name"
    fi
done)
# display_name_for_session: ~2 subprocesses per path (basename + tr), grep for most rows.
subprocess_estimate=$((option_count * project_path_count * 2 + option_count))
echo "estimated_subprocesses_in_select_loop=$subprocess_estimate" >>"$log"
tick "build select_options (grep-in-loop path)"

select_line_count=$(printf '%s\n' "$select_options" | sed '/^$/d' | wc -l | tr -d ' ')
tick "select_options lines (count=$select_line_count)"

sorted_options=$(printf '%s\n' "$select_options" | sort -r)
tick "sort -r select_options"

if [ "$profile_fzf" = 1 ]; then
    selected_option=$(printf '%s\n' "$sorted_options" | fzf --ansi --tmux 80% --delimiter="$(printf '\t')" --with-nth=1)
    tick "fzf interactive (user selected or cancelled)"
    if [ -n "$selected_option" ]; then
        echo "selected=$(printf '%s' "$selected_option" | cut -f2)" >>"$log"
    fi
else
    # Non-interactive: measure fzf filter-only (no popup).
    printf '%s\n' "$sorted_options" | fzf --filter '' --exit-0 >/dev/null 2>>"$log" || true
    tick "fzf --filter '' --exit-0 (non-interactive smoke)"
fi

tick "done"
echo >>"$log"

cat "$log"
